# Tankerkönig API key — get one for free at:
# https://creativecommons.tankerkoenig.de/#about
TANKERKOENIG_API_KEY=

# Photon (komoot) geocoder identifier — REQUIRED.
# Server refuses to boot without this. Identify your app and a contact so
# komoot can reach you if your usage ever misbehaves.
PHOTON_USER_AGENT=gas-price-monitor (you@example.com)

# Optional: override the Photon base URL (mainly for testing or self-hosting).
# PHOTON_BASE_URL=https://photon.komoot.io

# Geocoder cache (24h TTL, 200-entry LRU by default)
# GEOCODE_CACHE_TTL_MS=86400000
# GEOCODE_CACHE_MAX_ENTRIES=200

# OSRM (Open Source Routing Machine) identifier — REQUIRED.
# Powers driving-distance for the Best Value calc + the map's route polylines.
# Identify your app and a contact; the public demo instance is fair-use only.
OSRM_USER_AGENT=gas-price-monitor (you@example.com)

# Optional: override the OSRM base URL (point at a self-hosted instance if you
# outgrow the public demo).
# OSRM_BASE_URL=https://router.project-osrm.org

# OSRM cache (7-day TTL, 500-entry LRU by default)
# OSRM_CACHE_TTL_MS=604800000
# OSRM_CACHE_MAX_ENTRIES=500

# Stadia Maps tile-provider API key (optional). Sign up at
# https://stadiamaps.com/. If unset, the map falls back to OSM raw tiles which
# have stricter fair-use limits for public-facing deployments.
# STADIA_API_KEY=

# Server port (optional, defaults to 3000)
# PORT=3000

# Default map center if the browser has no saved preference.
# These default to Berlin Mitte.
# DEFAULT_LAT=52.5200
# DEFAULT_LNG=13.4050
# DEFAULT_RADIUS=5

# Storage locations (defaults relative to project root)
# CACHE_DIR=.cache
# DATA_DIR=data

# Price-drop alerts: set any of these to a € price per litre to fire alerts
# when the cheapest open station crosses below.
# ALERT_E5_BELOW=1.75
# ALERT_E10_BELOW=1.70
# ALERT_DIESEL_BELOW=1.55

# Alert dispatch (one or both)
# ALERT_DESKTOP_NOTIFY=true              # notify-send (Linux)
# ALERT_WEBHOOK_URL=https://ntfy.sh/...  # POST JSON on each alert
